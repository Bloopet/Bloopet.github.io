{
  "artifactDownloadUrl": "https://github.com/untitaker/hyperlink/releases/download/0.2.0",
  "bin": {
    "hyperlink": "run-hyperlink.js"
  },
  "contributors": [
    "Markus Unterwaditzer <markus-honeypot@unterwaditzer.net>",
    "Michael Clayton <mclayton@redhat.com>"
